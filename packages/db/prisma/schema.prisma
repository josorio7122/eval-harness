generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Dataset {
  id          String            @id @default(uuid()) @db.Uuid
  name        String            @unique
  revisions   DatasetRevision[]
  experiments Experiment[]
}

model DatasetRevision {
  id            String                @id @default(uuid()) @db.Uuid
  datasetId     String                @db.Uuid
  schemaVersion Int
  attributes    String[]
  createdAt     DateTime              @default(now())
  dataset       Dataset               @relation(fields: [datasetId], references: [id], onDelete: Cascade)
  items         DatasetRevisionItem[]
  experiments   Experiment[]

  @@index([datasetId])
}

model DatasetRevisionItem {
  id         String             @id @default(uuid()) @db.Uuid
  revisionId String             @db.Uuid
  itemId     String             @db.Uuid
  values     Json
  createdAt  DateTime           @default(now())
  revision   DatasetRevision    @relation(fields: [revisionId], references: [id], onDelete: Cascade)
  results    ExperimentResult[]

  @@index([revisionId])
  @@index([itemId])
}

model Grader {
  id          String             @id @default(uuid()) @db.Uuid
  name        String             @unique
  description String             @default("")
  rubric      String
  experiments ExperimentGrader[]
  results     ExperimentResult[]
}

model Experiment {
  id                String             @id @default(uuid()) @db.Uuid
  name              String
  datasetId         String             @db.Uuid
  datasetRevisionId String             @db.Uuid
  status            String             @default("queued")
  modelId           String             @default("google/gemini-2.5-flash")
  dataset           Dataset            @relation(fields: [datasetId], references: [id], onDelete: Cascade)
  revision          DatasetRevision    @relation(fields: [datasetRevisionId], references: [id])
  graders           ExperimentGrader[]
  results           ExperimentResult[]

  @@index([datasetId])
  @@index([datasetRevisionId])
}

model ExperimentGrader {
  experimentId String     @db.Uuid
  graderId     String     @db.Uuid
  experiment   Experiment @relation(fields: [experimentId], references: [id], onDelete: Cascade)
  grader       Grader     @relation(fields: [graderId], references: [id], onDelete: Cascade)

  @@id([experimentId, graderId])
  @@index([graderId])
}

model ExperimentResult {
  id                    String              @id @default(uuid()) @db.Uuid
  experimentId          String              @db.Uuid
  datasetRevisionItemId String              @db.Uuid
  graderId              String              @db.Uuid
  verdict               String
  reason                String              @default("")
  experiment            Experiment          @relation(fields: [experimentId], references: [id], onDelete: Cascade)
  datasetRevisionItem   DatasetRevisionItem @relation(fields: [datasetRevisionItemId], references: [id], onDelete: Cascade)
  grader                Grader              @relation(fields: [graderId], references: [id], onDelete: Restrict)

  @@unique([experimentId, datasetRevisionItemId, graderId])
  @@index([experimentId])
  @@index([datasetRevisionItemId])
  @@index([graderId])
}
